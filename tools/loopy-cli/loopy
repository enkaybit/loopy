def _ensure_state_scaffold() -> dict:
    data = read_state()
    data.setdefault("schema_version", 1)
    data.setdefault("branch", current_branch())
    data.setdefault("stage", "unknown")
    data.setdefault("section_baselines", {})
    data.setdefault("reviews", [])
    data.setdefault("budget", {"entries": [], "totals": {}})
    return data


def cmd_state_show(args: argparse.Namespace) -> int:
    data = read_state()
    if args.json:
        print(json.dumps(data, indent=2, default=str))
    else:
        if not data:
            print(f"(no state file at {state_path()})")
            return 0
        print(yaml_dump(data).rstrip())
    return 0


def cmd_state_set(args: argparse.Namespace) -> int:
    data = _ensure_state_scaffold()
    # Parse value — try int, float, bool, else string.
    raw = args.value
    val: Any
    if raw.lower() in {"true", "false"}:
        val = raw.lower() == "true"
    elif re.fullmatch(r"-?\d+", raw):
        val = int(raw)
    elif re.fullmatch(r"-?\d+\.\d+", raw):
        val = float(raw)
    else:
        val = raw
    # Support dotted keys up to two levels (e.g., plan, prd, feature).
    parts = args.key.split(".")
    ref = data
    for p in parts[:-1]:
        ref = ref.setdefault(p, {})
        if not isinstance(ref, dict):
            print(f"error: cannot set nested key under non-mapping at '{p}'", file=sys.stderr)
            return 2
    ref[parts[-1]] = val
    write_state(data)
    print(f"set {args.key} = {val!r}")
    return 0


def cmd_state_baseline(args: argparse.Namespace) -> int:
    data = _ensure_state_scaffold()
    data["section_baselines"][str(args.section)] = args.sha
    write_state(data)
    print(f"recorded baseline: section {args.section} @ {args.sha}")
    return 0


def cmd_state_review_add(args: argparse.Namespace) -> int:
    data = _ensure_state_scaffold()
    entry = {
        "scope": args.scope,
        "path": args.path,
        "recorded_at": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }
    data.setdefault("reviews", []).append(entry)
    write_state(data)
    print(f"review recorded: scope={args.scope} path={args.path}")
    return 0


