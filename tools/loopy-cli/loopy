# Subcommand: browser-capture
# ---------------------------------------------------------------------------


def cmd_browser_capture(args: argparse.Namespace) -> int:
    """Thin wrapper around `agent-browser` for spike / review screenshots.

    Non-goals: this is not a full browser-automation surface. For anything
    beyond 'open URL, take screenshot', call agent-browser directly via the
    loopy-browse skill. This wrapper exists so skills can rely on a
    stable CLI contract with clear exit codes:

        0  success
        2  bad arguments / fs error
        3  agent-browser not installed (skills should degrade gracefully)
        4  agent-browser ran but failed (timeouts, navigation errors, etc.)
    """
    import shutil
    if shutil.which("agent-browser") is None:
        print(
            "agent-browser is not installed. Install with 'npm install -g agent-browser' "
            "and 'agent-browser install'. Skipping capture.",
            file=sys.stderr,
        )
        return 3

    out = pathlib.Path(args.output)
    if out.is_dir():
        print(f"error: output path is a directory: {out}", file=sys.stderr)
        return 2
    out.parent.mkdir(parents=True, exist_ok=True)

    cmd = ["agent-browser", "open", args.url]
    if args.session:
        cmd = ["agent-browser", "--session", args.session, "open", args.url]
    try:
        subprocess.run(cmd, check=True, capture_output=True, text=True)
        wait_cmd = ["agent-browser"]
        if args.session:
            wait_cmd += ["--session", args.session]
        wait_cmd += ["wait", "--load", "networkidle"]
        # Don't fail hard on wait errors — some pages never reach idle.
        subprocess.run(wait_cmd, check=False, capture_output=True, text=True, timeout=args.timeout)
        shot_cmd = ["agent-browser"]
        if args.session:
            shot_cmd += ["--session", args.session]
        shot_cmd += ["screenshot", str(out)]
        if args.full:
            shot_cmd.append("--full")
        subprocess.run(shot_cmd, check=True, capture_output=True, text=True, timeout=args.timeout)
    except subprocess.CalledProcessError as e:
        print(f"agent-browser failed: {e.stderr or e.stdout or e}", file=sys.stderr)
        return 4
    except subprocess.TimeoutExpired as e:
        print(f"agent-browser timed out: {e}", file=sys.stderr)
        return 4

    if not out.exists():
        print(f"agent-browser returned 0 but no file at {out}", file=sys.stderr)
        return 4
    print(str(out))
    return 0


