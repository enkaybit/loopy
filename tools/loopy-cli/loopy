BUDGET_KINDS = {"tokens", "seconds", "usd"}


def cmd_budget_add(args: argparse.Namespace) -> int:
    if args.kind not in BUDGET_KINDS:
        print(f"error: kind must be one of {sorted(BUDGET_KINDS)}", file=sys.stderr)
        return 2
    try:
        amount = float(args.amount)
    except ValueError:
        print("error: amount must be a number", file=sys.stderr)
        return 2
    data = _ensure_state_scaffold()
    data["budget"].setdefault("entries", [])
    data["budget"]["entries"].append(
        {
            "kind": args.kind,
            "amount": amount,
            "stage": args.stage or "unknown",
            "note": args.note or "",
            "at": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        }
    )
    totals = data["budget"].setdefault("totals", {})
    totals[args.kind] = float(totals.get(args.kind, 0)) + amount
    write_state(data)
    print(f"budget +{amount} {args.kind} (stage={args.stage}) — total {args.kind}={totals[args.kind]}")
    return 0


def cmd_budget_summary(args: argparse.Namespace) -> int:
    data = read_state()
    budget = (data or {}).get("budget") or {}
    totals = budget.get("totals") or {}
    entries = budget.get("entries") or []
    if args.json:
        print(json.dumps({"totals": totals, "entries": entries}, indent=2, default=str))
        return 0
    print("Budget summary")
    print("--------------")
    if not totals:
        print("(no entries)")
        return 0
    for kind in sorted(totals.keys()):
        print(f"  {kind}: {totals[kind]}")
    # Per-stage breakdown
    by_stage: dict[str, dict[str, float]] = {}
    for e in entries:
        stage = str(e.get("stage", "unknown"))
        kind = str(e.get("kind", "?"))
        by_stage.setdefault(stage, {}).setdefault(kind, 0.0)
        by_stage[stage][kind] += float(e.get("amount", 0))
    if by_stage:
        print()
        print("By stage:")
        for stage in sorted(by_stage.keys()):
            kinds = ", ".join(f"{k}={v}" for k, v in sorted(by_stage[stage].items()))
            print(f"  {stage}: {kinds}")
    return 0


# ---------------------------------------------------------------------------
# Argparse wiring
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="loopy", description="loopy SDLC helper CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    # validate
    v = sub.add_parser("validate", help="Validate PRD or plan against the schema")
    vsub = v.add_subparsers(dest="kind", required=True)
    for k in ("prd", "plan"):
        pv = vsub.add_parser(k, help=f"Validate a {k.upper() if k == 'prd' else k} document")
        pv.add_argument("path")
        pv.add_argument("--json", action="store_true", help="Emit JSON output")
        pv.set_defaults(func=cmd_validate, kind=k)

    # state
    st = sub.add_parser("state", help="Inspect/update pipeline state (.loopy/state.yml)")
    stsub = st.add_subparsers(dest="subcmd", required=True)
    show = stsub.add_parser("show", help="Show the state file")
    show.add_argument("--json", action="store_true")
    show.set_defaults(func=cmd_state_show)
    sset = stsub.add_parser("set", help="Set a scalar key (supports dotted paths)")
    sset.add_argument("key")
    sset.add_argument("value")
    sset.set_defaults(func=cmd_state_set)
    bl = stsub.add_parser("section-baseline", help="Record a plan section's baseline SHA")
    bl.add_argument("section")
    bl.add_argument("sha")
    bl.set_defaults(func=cmd_state_baseline)
    rv = stsub.add_parser("review-add", help="Append a review record to state")
    rv.add_argument("scope")
    rv.add_argument("path")
    rv.set_defaults(func=cmd_state_review_add)

    # verify-tests
    vt = sub.add_parser("verify-tests", help="Check that a feature subtask produced matching test cases")
    vt.add_argument("plan")
    vt.add_argument("subtask", help="Subtask id, e.g. 1.2")
    vt.set_defaults(func=cmd_verify_tests)

    # review-save
    rs = sub.add_parser("review-save", help="Persist a review report and link from plan")
    rs.add_argument("scope", help="Review scope label, e.g. section-1 / final / branch")
    grp = rs.add_mutually_exclusive_group(required=True)
    grp.add_argument("--stdin", action="store_true", help="Read review body from stdin")
    grp.add_argument("--content", help="Inline review body")
    rs.add_argument("--plan", help="Plan path to link from (relative to repo root)")
    rs.add_argument("--base-sha", help="Base SHA the review was scoped to")
    rs.add_argument(
        "--attach",
        action="append",
        default=[],
        help="Attach a file (screenshot / log / etc.). Repeatable. Switches output to a review directory with index.md.",
    )
    rs.set_defaults(func=cmd_review_save)

    # browser-capture
    bc = sub.add_parser(
        "browser-capture",
        help="Open a URL in agent-browser and write a screenshot. Exits 3 if agent-browser is not installed.",
    )
    bc.add_argument("url")
    bc.add_argument("output", help="Screenshot output path (e.g. docs/spikes/.../screenshot.png)")
    bc.add_argument("--full", action="store_true", help="Capture full page (pass --full to agent-browser)")
    bc.add_argument("--session", help="agent-browser session name (for persisted cookies/auth)")
    bc.add_argument("--timeout", type=int, default=30, help="Per-step timeout in seconds (default 30)")
    bc.set_defaults(func=cmd_browser_capture)

    # budget
    bg = sub.add_parser("budget", help="Track token/time/usd budget across the workflow")
    bgsub = bg.add_subparsers(dest="subcmd", required=True)
    ba = bgsub.add_parser("add", help="Record a budget entry")
    ba.add_argument("kind", choices=sorted(BUDGET_KINDS))
    ba.add_argument("amount")
    ba.add_argument("--stage", help="Which workflow stage (requirements/plan/build/review/wrapup)")
    ba.add_argument("--note", help="Free-form note")
    ba.set_defaults(func=cmd_budget_add)
    bs = bgsub.add_parser("summary", help="Print a budget summary")
    bs.add_argument("--json", action="store_true")
    bs.set_defaults(func=cmd_budget_summary)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args) or 0)


if __name__ == "__main__":
    sys.exit(main())
