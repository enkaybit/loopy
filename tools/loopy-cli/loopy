def cmd_validate(args: argparse.Namespace) -> int:
    path = pathlib.Path(args.path)
    if args.kind == "prd":
        errors = validate_prd(path)
    elif args.kind == "plan":
        errors = validate_plan(path)
    else:
        print(f"unknown validate kind: {args.kind}", file=sys.stderr)
        return 2
    if args.json:
        print(json.dumps({"path": str(path), "kind": args.kind, "errors": errors}, indent=2))
    else:
        if errors:
            print(f"FAIL: {path} ({args.kind}) — {len(errors)} error(s):")
            for e in errors:
                print(f"  - {e}")
        else:
            print(f"OK: {path} ({args.kind}) — schema valid")
    return 1 if errors else 0


