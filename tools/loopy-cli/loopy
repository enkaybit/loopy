#!/usr/bin/env python3
"""
loopy — structural helper CLI for the loopy SDLC workflow.

Subcommands (read-only unless noted):
  validate prd <path>             Validate a PRD markdown file against the schema.
  validate plan <path>            Validate a tech plan markdown file against the schema.
  state show                      Print current pipeline state for this branch (.loopy/state.yml).
  state set <key> <value>         Set a top-level scalar key in .loopy/state.yml (writes).
  state section-baseline <id> <sha>   Record a section baseline SHA (writes).
  state review-add <scope> <path> Append a review record (writes).
  verify-tests <plan> <subtask>   Heuristic check that tests were written for a feature subtask.
  review-save <scope> --stdin     Persist a review report to docs/reviews/ and link from plan (writes).
                                  Supports repeatable --attach <file> to embed screenshots / other evidence.
  browser-capture <url> <out>     Thin wrapper over `agent-browser`: open URL, screenshot to <out>.
                                  Exits 3 (not 1) when agent-browser is not installed, so skills can branch.
  budget add <kind> <amount>      Append a budget entry (kind=tokens|seconds|usd) (writes).
  budget summary                  Print a budget summary for current state.

All subcommands exit 0 on success and non-zero on schema / validation failure.
Only stdlib is used — no external dependencies.
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import pathlib
import re
import subprocess
import sys
from typing import Any


# ---------------------------------------------------------------------------
# Minimal YAML writer/reader (subset: flat mappings, lists of mappings, scalars)
# We deliberately don't pull in PyYAML — stdlib only.
# ---------------------------------------------------------------------------


class MiniYAMLError(Exception):
    pass


def _yaml_scalar(v: Any) -> str:
    if isinstance(v, bool):
        return "true" if v else "false"
    if v is None:
        return "null"
    if isinstance(v, (int, float)):
        return str(v)
    s = str(v)
    # Quote if it contains YAML-significant chars or leading/trailing whitespace.
    if s == "" or re.search(r"[:#\[\]\{\},&*!|>'\"%@`]", s) or s.strip() != s or s.lower() in {"true", "false", "null", "yes", "no"}:
        return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'
    return s


def yaml_dump(data: Any, indent: int = 0) -> str:
    """Serialize a nested dict/list/scalar to a YAML subset.

    Layout rules (matched by ``yaml_load`` below):
      - 2-space indents, block style only.
      - Mappings: ``key: value`` on one line, nested mappings on following lines.
      - Lists of scalars:   ``- value`` at the same indent as siblings.
      - Lists of mappings:  each mapping's first key on the same line as ``- ``;
        subsequent keys indented two spaces beyond ``- `` (i.e., aligned with
        the first key).
    """
    pad = "  " * indent
    lines: list[str] = []
    _emit(data, indent, lines, in_list_item=False)
    text = "\n".join(lines)
    return text + ("\n" if not text.endswith("\n") else "")


def _emit(data: Any, indent: int, lines: list[str], in_list_item: bool) -> None:
    pad = "  " * indent
    if isinstance(data, dict):
        if not data:
            lines.append(f"{pad}{{}}")
            return
        items = list(data.items())
        for i, (k, v) in enumerate(items):
            key = _yaml_scalar(k)
            prefix = pad
            if in_list_item and i == 0:
                # The caller already emitted "- " at (indent-1)*2 + 2 cols; we
                # need to put the first key flush with that. Callers use indent
                # equal to the content column, so pad is correct.
                prefix = ""  # caller writes '- ' then we append "key: ..." without pad
            if isinstance(v, dict):
                if not v:
                    lines.append(f"{prefix}{key}: {{}}")
                else:
                    lines.append(f"{prefix}{key}:")
                    _emit(v, indent + 1, lines, in_list_item=False)
            elif isinstance(v, list):
                if not v:
                    lines.append(f"{prefix}{key}: []")
                else:
                    lines.append(f"{prefix}{key}:")
                    child_pad = "  " * (indent + 1)
                    for item in v:
                        if isinstance(item, dict):
                            if not item:
                                lines.append(f"{child_pad}- {{}}")
                                continue
                            # Emit '- ' followed by first key:value, then remaining keys aligned.
                            sub_items = list(item.items())
                            fk, fv = sub_items[0]
                            if isinstance(fv, (dict, list)):
                                lines.append(f"{child_pad}- {_yaml_scalar(fk)}:")
                                if isinstance(fv, dict) and fv:
                                    _emit(fv, indent + 3, lines, in_list_item=False)
                                elif isinstance(fv, list) and fv:
                                    fv_pad = "  " * (indent + 3)
                                    for el in fv:
                                        if isinstance(el, dict):
                                            # recurse at indent+2 as a list
                                            _emit([el], indent + 2, lines, in_list_item=False)
                                        else:
                                            lines.append(f"{fv_pad}- {_yaml_scalar(el)}")
                                else:
                                    lines.append(f"{child_pad}  {'{}' if isinstance(fv, dict) else '[]'}")
                            else:
                                lines.append(f"{child_pad}- {_yaml_scalar(fk)}: {_yaml_scalar(fv)}")
                            rest_pad = "  " * (indent + 2)
                            for k2, v2 in sub_items[1:]:
                                k2s = _yaml_scalar(k2)
                                if isinstance(v2, dict):
                                    if not v2:
                                        lines.append(f"{rest_pad}{k2s}: {{}}")
                                    else:
                                        lines.append(f"{rest_pad}{k2s}:")
                                        _emit(v2, indent + 3, lines, in_list_item=False)
                                elif isinstance(v2, list):
                                    if not v2:
                                        lines.append(f"{rest_pad}{k2s}: []")
                                    else:
                                        lines.append(f"{rest_pad}{k2s}:")
                                        nested = "  " * (indent + 3)
                                        for el in v2:
                                            if isinstance(el, dict):
                                                _emit([el], indent + 3, lines, in_list_item=False)
                                            else:
                                                lines.append(f"{nested}- {_yaml_scalar(el)}")
                                else:
                                    lines.append(f"{rest_pad}{k2s}: {_yaml_scalar(v2)}")
                        else:
                            lines.append(f"{child_pad}- {_yaml_scalar(item)}")
            else:
                lines.append(f"{prefix}{key}: {_yaml_scalar(v)}")
            # After first list-item key, subsequent keys must carry indent (pad), not empty prefix.
            if in_list_item and i == 0:
                in_list_item = False
        return
    if isinstance(data, list):
        if not data:
            lines.append(f"{pad}[]")
            return
        for item in data:
            if isinstance(item, dict):
                if not item:
                    lines.append(f"{pad}- {{}}")
                    continue
                sub_items = list(item.items())
                fk, fv = sub_items[0]
                if isinstance(fv, (dict, list)):
                    lines.append(f"{pad}- {_yaml_scalar(fk)}:")
                    if isinstance(fv, dict) and fv:
                        _emit(fv, indent + 2, lines, in_list_item=False)
                    elif isinstance(fv, list) and fv:
                        nested = "  " * (indent + 2)
                        for el in fv:
                            if isinstance(el, dict):
                                _emit([el], indent + 2, lines, in_list_item=False)
                            else:
                                lines.append(f"{nested}- {_yaml_scalar(el)}")
                else:
                    lines.append(f"{pad}- {_yaml_scalar(fk)}: {_yaml_scalar(fv)}")
                rest_pad = "  " * (indent + 1)
                for k2, v2 in sub_items[1:]:
                    k2s = _yaml_scalar(k2)
                    if isinstance(v2, dict):
                        if not v2:
                            lines.append(f"{rest_pad}{k2s}: {{}}")
                        else:
                            lines.append(f"{rest_pad}{k2s}:")
                            _emit(v2, indent + 2, lines, in_list_item=False)
                    elif isinstance(v2, list):
                        if not v2:
                            lines.append(f"{rest_pad}{k2s}: []")
                        else:
                            lines.append(f"{rest_pad}{k2s}:")
                            nested = "  " * (indent + 2)
                            for el in v2:
                                if isinstance(el, dict):
                                    _emit([el], indent + 2, lines, in_list_item=False)
                                else:
                                    lines.append(f"{nested}- {_yaml_scalar(el)}")
                    else:
                        lines.append(f"{rest_pad}{k2s}: {_yaml_scalar(v2)}")
            else:
                lines.append(f"{pad}- {_yaml_scalar(item)}")
        return
    # scalar
    lines.append(f"{pad}{_yaml_scalar(data)}")


def yaml_load(text: str) -> Any:
    """Parse the subset of YAML that we write ourselves.

    Supports:
      - mappings (``key: value``)
      - nested mappings by 2-space indent
      - lists of scalars or mappings (``- value`` / ``- key: v``)
      - quoted and unquoted scalars, integers, floats, booleans, null
    """
    lines = [ln.rstrip("\n") for ln in text.split("\n") if ln.strip() and not ln.lstrip().startswith("#")]
    idx = 0

    def parse_scalar(s: str) -> Any:
        s = s.strip()
        if s == "" or s == "~" or s.lower() == "null":
            return None
        if s.lower() == "true":
            return True
        if s.lower() == "false":
            return False
        if (s.startswith('"') and s.endswith('"')) or (s.startswith("'") and s.endswith("'")):
            return s[1:-1].replace('\\"', '"').replace("\\\\", "\\")
        try:
            if re.fullmatch(r"-?\d+", s):
                return int(s)
            if re.fullmatch(r"-?\d+\.\d+", s):
                return float(s)
        except ValueError:
            pass
        return s

    def indent_of(ln: str) -> int:
        return len(ln) - len(ln.lstrip(" "))

    def parse_block(base_indent: int) -> Any:
        nonlocal idx
        # Decide: mapping vs list based on first token at base_indent.
        if idx >= len(lines):
            return None
        first = lines[idx]
        if indent_of(first) < base_indent:
            return None
        if first.lstrip().startswith("- "):
            return parse_list(base_indent)
        return parse_map(base_indent)

    def parse_map(base_indent: int) -> dict:
        nonlocal idx
        result: dict = {}
        while idx < len(lines):
            ln = lines[idx]
            ind = indent_of(ln)
            if ind < base_indent:
                break
            if ind > base_indent:
                raise MiniYAMLError(f"unexpected indent at line: {ln!r}")
            stripped = ln.lstrip()
            if stripped.startswith("- "):
                break
            m = re.match(r"([A-Za-z0-9_./@-]+|\"[^\"]+\"|'[^']+'):\s*(.*)$", stripped)
            if not m:
                raise MiniYAMLError(f"unparsable line: {ln!r}")
            raw_key = m.group(1)
            if raw_key.startswith(('"', "'")):
                key = raw_key[1:-1]
            else:
                key = raw_key
            rest = m.group(2)
            idx += 1
            if rest == "" or rest is None:
                # Nested structure
                if idx < len(lines) and indent_of(lines[idx]) > base_indent:
                    child_indent = indent_of(lines[idx])
                    result[key] = parse_block(child_indent)
                else:
                    result[key] = None
            elif rest == "{}":
                result[key] = {}
            elif rest == "[]":
                result[key] = []
            else:
                result[key] = parse_scalar(rest)
        return result

    def parse_list(base_indent: int) -> list:
        nonlocal idx
        result: list = []
        while idx < len(lines):
            ln = lines[idx]
            ind = indent_of(ln)
            if ind < base_indent:
                break
            stripped = ln.lstrip()
            if not stripped.startswith("- "):
                break
            item_body = stripped[2:]
            idx += 1
            # If item body has "k: v", treat as inline mapping entry — may continue on subsequent indented lines.
            if re.match(r"[A-Za-z0-9_./@-]+\s*:", item_body) or (
                item_body.startswith('"') and '":' in item_body
            ):
                # Reinsert as a virtual map line under this list item.
                inline_indent = base_indent + 2
                # Build a sub-map starting with this key.
                virtual_line = " " * inline_indent + item_body
                lines.insert(idx, virtual_line)
                m = parse_map(inline_indent)
                result.append(m)
            elif item_body == "" or item_body is None:
                # Nested mapping on subsequent lines.
                if idx < len(lines) and indent_of(lines[idx]) > base_indent:
                    result.append(parse_block(indent_of(lines[idx])))
                else:
                    result.append(None)
            else:
                result.append(parse_scalar(item_body))
        return result

    if not lines:
        return {}
    root_indent = indent_of(lines[0])
    return parse_block(root_indent) if lines else {}


# ---------------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------------


def repo_root() -> pathlib.Path:
    try:
        out = subprocess.check_output(["git", "rev-parse", "--show-toplevel"], stderr=subprocess.DEVNULL)
        return pathlib.Path(out.decode().strip())
    except subprocess.CalledProcessError:
        return pathlib.Path.cwd()


def current_branch() -> str:
    try:
        out = subprocess.check_output(["git", "rev-parse", "--abbrev-ref", "HEAD"], stderr=subprocess.DEVNULL)
        return out.decode().strip()
    except subprocess.CalledProcessError:
        return "HEAD"


def state_path(root: pathlib.Path | None = None) -> pathlib.Path:
    root = root or repo_root()
    return root / ".loopy" / "state.yml"


def read_state(root: pathlib.Path | None = None) -> dict:
    sp = state_path(root)
    if not sp.exists():
        return {}
    try:
        return yaml_load(sp.read_text()) or {}
    except MiniYAMLError as e:
        raise SystemExit(f"error: failed to parse {sp}: {e}")


def write_state(data: dict, root: pathlib.Path | None = None) -> pathlib.Path:
    sp = state_path(root)
    sp.parent.mkdir(parents=True, exist_ok=True)
    data.setdefault("schema_version", 1)
    data["last_updated"] = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    sp.write_text(yaml_dump(data))
    return sp


# ---------------------------------------------------------------------------
# Schema: PRD validator
# ---------------------------------------------------------------------------


REQ_ID_RE = re.compile(r"^R\d+$")
REQ_PRIORITIES = {"Core", "Must", "Nice", "Out"}


def _extract_section(md: str, heading_re: str) -> str | None:
    """Extract content under the first heading matching the regex, until the next heading of same or higher level."""
    lines = md.split("\n")
    out: list[str] = []
    start = None
    start_level = None
    pat = re.compile(heading_re)
    for i, ln in enumerate(lines):
        m = re.match(r"^(#{1,6})\s+(.*)$", ln)
        if m:
            level = len(m.group(1))
            if start is None:
                if pat.search(m.group(2)):
                    start = i + 1
                    start_level = level
                continue
            if level <= start_level:
                break
        if start is not None:
            out.append(ln)
    return "\n".join(out) if start is not None else None


def _first_table(text: str) -> list[list[str]] | None:
    """Return a parsed markdown pipe-table (header row + data rows) or None."""
    lines = text.split("\n")
    # Find the header (line) + separator (|---|---|).
    for i in range(len(lines) - 1):
        header = lines[i].strip()
        sep = lines[i + 1].strip()
        if header.startswith("|") and re.match(r"^\|?[\s:|-]+\|[\s:|-]+\|?$", sep):
            rows: list[list[str]] = []
            def _split(row: str) -> list[str]:
                parts = [c.strip() for c in row.strip().strip("|").split("|")]
                return parts
            rows.append(_split(header))
            for j in range(i + 2, len(lines)):
                row = lines[j].strip()
                if not row.startswith("|"):
                    break
                rows.append(_split(row))
            return rows
    return None


def validate_prd(path: pathlib.Path) -> list[str]:
    errors: list[str] = []
    if not path.exists():
        return [f"PRD not found: {path}"]
    md = path.read_text()

    # Required top-level sections
    for heading in ["Goal", "Scope", "Requirements", "Next Steps"]:
        if _extract_section(md, rf"^{re.escape(heading)}\b") is None:
            errors.append(f"missing required section: ## {heading}")

    # Requirements table
    req_section = _extract_section(md, r"^Requirements\b")
    if req_section is not None:
        tbl = _first_table(req_section)
        if tbl is None:
            errors.append("Requirements section: no markdown table found")
        else:
            header = [c.lower() for c in tbl[0]]
            expected = ["id", "priority", "requirement"]
            if header[:3] != expected:
                errors.append(
                    f"Requirements table header must be 'ID | Priority | Requirement', got: {' | '.join(tbl[0])}"
                )
            seen_ids: set[str] = set()
            for row_idx, row in enumerate(tbl[1:], start=1):
                if len(row) < 3:
                    errors.append(f"Requirements row {row_idx}: fewer than 3 columns")
                    continue
                rid, prio, text = row[0], row[1], row[2]
                if not REQ_ID_RE.match(rid):
                    errors.append(f"Requirements row {row_idx}: ID '{rid}' must match /^R\\d+$/")
                elif rid in seen_ids:
                    errors.append(f"Requirements row {row_idx}: duplicate ID '{rid}'")
                else:
                    seen_ids.add(rid)
                if prio not in REQ_PRIORITIES:
                    errors.append(
                        f"Requirements row {row_idx} ({rid}): priority '{prio}' must be one of {sorted(REQ_PRIORITIES)}"
                    )
                if not text:
                    errors.append(f"Requirements row {row_idx} ({rid}): requirement text is empty")

    # Scope section must contain "In Scope" and "Boundaries" subheadings
    scope = _extract_section(md, r"^Scope\b")
    if scope is not None:
        if not re.search(r"^###\s+In Scope\b", scope, re.M):
            errors.append("Scope section: missing '### In Scope'")
        if not re.search(r"^###\s+Boundaries\b", scope, re.M):
            errors.append("Scope section: missing '### Boundaries'")

    # Header metadata
    if not re.search(r"^\*\*Date:\*\*", md, re.M):
        errors.append("missing header: **Date:**")
    if not re.search(r"^\*\*Status:\*\*", md, re.M):
        errors.append("missing header: **Status:**")

    # Open Questions: each bullet should be tagged with [Affects ...]
    oq = _extract_section(md, r"^Open Questions\b")
    if oq is not None:
        for ln in oq.split("\n"):
            s = ln.strip()
            if s.startswith("- "):
                if not re.search(r"\[Affects\s+[^\]]+\]", s):
                    errors.append(f"Open Questions: bullet missing [Affects ...] tag: {s}")

    return errors


# ---------------------------------------------------------------------------
# Schema: Tech plan validator
# ---------------------------------------------------------------------------


SUBTASK_HEADING_RE = re.compile(r"^####\s+(\d+)\.(\d+)\s+(.+?)\s*$", re.M)
DEPENDS_RE = re.compile(r"^\*\*Depends on:\*\*\s*(.+?)\s*$", re.M)
FILES_RE = re.compile(r"^\*\*Files:\*\*\s*(.+?)\s*$", re.M)
TEST_SCENARIOS_RE = re.compile(r"^\*\*Test scenarios:\*\*\s*(?:\(([^)]+)\))?\s*$", re.M)
VERIFY_RE = re.compile(r"^\*\*Verify:\*\*\s*(.+?)\s*$", re.M)


def _parse_subtasks(md: str) -> list[dict]:
    """Split plan markdown into subtask dicts with extracted fields."""
    # Find all subtask headings and their byte offsets.
    matches = list(SUBTASK_HEADING_RE.finditer(md))
    subtasks: list[dict] = []
    for i, m in enumerate(matches):
        start = m.end()
        end = matches[i + 1].start() if i + 1 < len(matches) else len(md)
        body = md[start:end]
        depends_m = DEPENDS_RE.search(body)
        files_m = FILES_RE.search(body)
        ts_m = TEST_SCENARIOS_RE.search(body)
        verify_m = VERIFY_RE.search(body)
        parent = int(m.group(1))
        child = int(m.group(2))
        sid = f"{parent}.{child}"

        depends: list[str] = []
        if depends_m:
            raw = depends_m.group(1).strip()
            if raw.lower() != "none":
                depends = [d.strip() for d in raw.split(",") if d.strip()]

        files: list[str] = []
        if files_m:
            # Files field contains backtick-wrapped paths comma-separated.
            files = [p.strip("` ") for p in files_m.group(1).split(",") if p.strip()]

        ts_scenarios_start = ts_m.end() if ts_m else None
        # Scenario bullets: lines starting with "- " directly after the Test scenarios header,
        # until a blank line followed by another header (bold line) or next subtask.
        scenarios: list[str] = []
        if ts_scenarios_start is not None:
            rest = body[ts_scenarios_start:]
            for ln in rest.split("\n"):
                s = ln.strip()
                if s.startswith("- "):
                    scenarios.append(s[2:].strip())
                elif s.startswith("**") or s.startswith("####"):
                    break
                elif s == "":
                    # allow blank lines in the middle
                    if scenarios and not any(
                        l.strip().startswith("- ") for l in rest.split("\n")[rest.split("\n").index(ln) + 1:]
                    ):
                        break
                    continue

        subtasks.append(
            {
                "id": sid,
                "title": m.group(3).strip(),
                "parent": parent,
                "child": child,
                "depends_on": depends,
                "files": files,
                "test_scenarios": scenarios,
                "test_file": (ts_m.group(1).strip().strip('`').strip() if ts_m and ts_m.group(1) else None),
                "verify": (verify_m.group(1).strip() if verify_m else None),
                "body": body,
            }
        )
    return subtasks


# Subtasks whose title strongly implies a feature (needs tests). Keep broad.
FEATURE_KEYWORDS = re.compile(r"\b(add|implement|build|create|introduce|support|fix|handle|validate)\b", re.I)
# Subtasks that look infrastructural/config — override FEATURE_KEYWORDS when present.
NONFEATURE_KEYWORDS = re.compile(
    r"\b(config|configs|docs?|documentation|rename|move|bump|update\s+deps|refactor\s+only|readme|"
    r"install|installer|binar(?:y|ies)|script|scripts|changelog|license|gitignore|makefile)\b",
    re.I,
)


def is_feature_subtask(s: dict) -> bool:
    title = s["title"]
    # If there are any test scenarios declared in the plan, trust that signal —
    # author is asserting it has testable behavior.
    if s["test_scenarios"]:
        return True
    # Explicit non-feature cue in title takes precedence over feature verbs.
    if NONFEATURE_KEYWORDS.search(title):
        return False
    # Otherwise default to feature if title matches typical feature verbs.
    return bool(FEATURE_KEYWORDS.search(title))


def validate_plan(path: pathlib.Path) -> list[str]:
    errors: list[str] = []
    if not path.exists():
        return [f"Plan not found: {path}"]
    md = path.read_text()

    # Header fields
    if not re.search(r"^\*\*Date:\*\*", md, re.M):
        errors.append("missing header: **Date:**")
    if not re.search(r"^\*\*Status:\*\*", md, re.M):
        errors.append("missing header: **Status:**")
    if not re.search(r"^\*\*PRD:\*\*", md, re.M):
        errors.append("missing header: **PRD:**  (use 'None' if no PRD exists)")

    if not re.search(r"^##\s+Overview\b", md, re.M):
        errors.append("missing section: ## Overview")
    if not re.search(r"^##\s+Architecture\b", md, re.M):
        errors.append("missing section: ## Architecture")

    subtasks = _parse_subtasks(md)
    if not subtasks:
        errors.append("no subtasks found (expected '#### N.M Title' headings)")
        return errors

    # Check numbering: each parent's subtasks must be 1..K without gaps.
    by_parent: dict[int, list[int]] = {}
    for s in subtasks:
        by_parent.setdefault(s["parent"], []).append(s["child"])
    for parent, children in by_parent.items():
        children_sorted = sorted(children)
        expected = list(range(1, len(children_sorted) + 1))
        if children_sorted != expected:
            errors.append(
                f"parent {parent}: subtask numbering has gaps or duplicates "
                f"(got {children_sorted}, expected {expected})"
            )

    # Validate each subtask
    ids = {s["id"] for s in subtasks}
    for s in subtasks:
        sid = s["id"]
        prefix = f"subtask {sid} ({s['title']})"
        # Depends on
        if DEPENDS_RE.search(s["body"]) is None:
            errors.append(f"{prefix}: missing **Depends on:** field")
        for dep in s["depends_on"]:
            if dep not in ids:
                errors.append(f"{prefix}: **Depends on:** references unknown subtask '{dep}'")
            if dep == sid:
                errors.append(f"{prefix}: cannot depend on itself")
        # Files
        if FILES_RE.search(s["body"]) is None:
            errors.append(f"{prefix}: missing **Files:** field")
        # Verify
        if VERIFY_RE.search(s["body"]) is None:
            errors.append(f"{prefix}: missing **Verify:** field")

        # Feature subtasks require test scenarios + a test file path.
        if is_feature_subtask(s):
            if TEST_SCENARIOS_RE.search(s["body"]) is None:
                errors.append(f"{prefix}: feature subtask missing **Test scenarios:** section")
            else:
                if not s["test_scenarios"]:
                    errors.append(f"{prefix}: **Test scenarios:** present but no scenario bullets")
                if not s["test_file"]:
                    errors.append(
                        f"{prefix}: feature subtask **Test scenarios:** missing test-file "
                        f"parenthetical, e.g. '**Test scenarios:** (path/to/test.ts)'"
                    )
                else:
                    if s["test_file"] not in s["files"]:
                        errors.append(
                            f"{prefix}: test file '{s['test_file']}' from Test scenarios "
                            f"not listed in **Files:** ({s['files']})"
                        )

    # Cycle detection on depends_on (DFS).
    graph = {s["id"]: s["depends_on"] for s in subtasks}
    WHITE, GRAY, BLACK = 0, 1, 2
    color = {k: WHITE for k in graph}

    def dfs(node: str, path: list[str]) -> bool:
        color[node] = GRAY
        for nb in graph.get(node, []):
            if nb not in color:
                continue
            if color[nb] == GRAY:
                cycle = " -> ".join(path + [node, nb])
                errors.append(f"dependency cycle detected: {cycle}")
                return True
            if color[nb] == WHITE:
                if dfs(nb, path + [node]):
                    return True
        color[node] = BLACK
        return False

    for node in list(graph.keys()):
        if color[node] == WHITE:
            if dfs(node, []):
                break

    return errors


