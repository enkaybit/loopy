TEST_FUNC_PATTERNS = [
    re.compile(r"\bit\s*\(", re.M),           # Jest / Mocha
    re.compile(r"\btest\s*\(", re.M),         # Jest / Vitest
    re.compile(r"\bdescribe\s*\(", re.M),     # Jest / Mocha (block, ignored for count but signals tests exist)
    re.compile(r"^\s*def\s+test_\w+", re.M),  # Pytest
    re.compile(r"^func\s+Test\w+\s*\(", re.M),# Go
    re.compile(r"\b#\[test\]", re.M),         # Rust
]


def count_tests_in_file(path: pathlib.Path) -> int:
    try:
        text = path.read_text()
    except (OSError, UnicodeDecodeError):
        return 0
    # Strip describe() blocks from count — only count leaf tests (it/test/def test_/func Test/#[test]).
    leaf_patterns = [TEST_FUNC_PATTERNS[0], TEST_FUNC_PATTERNS[1], TEST_FUNC_PATTERNS[3], TEST_FUNC_PATTERNS[4], TEST_FUNC_PATTERNS[5]]
    total = 0
    for pat in leaf_patterns:
        total += len(pat.findall(text))
    return total


def cmd_verify_tests(args: argparse.Namespace) -> int:
    plan_path = pathlib.Path(args.plan)
    subs = _parse_subtasks(plan_path.read_text() if plan_path.exists() else "")
    target = None
    for s in subs:
        if s["id"] == args.subtask:
            target = s
            break
    if target is None:
        print(f"error: subtask {args.subtask} not found in {plan_path}", file=sys.stderr)
        return 2

    if not is_feature_subtask(target):
        print(f"OK: subtask {args.subtask} ({target['title']}) is not a feature subtask — skipped")
        return 0

    if not target["test_file"]:
        print(f"FAIL: subtask {args.subtask}: no test file parenthetical in Test scenarios", file=sys.stderr)
        return 1

    root = repo_root()
    tf = root / target["test_file"]
    if not tf.exists():
        print(f"FAIL: test file not found: {tf}", file=sys.stderr)
        return 1

    expected = len(target["test_scenarios"])
    actual = count_tests_in_file(tf)
    if expected == 0:
        print(f"WARN: subtask {args.subtask}: no scenarios declared in plan")
        return 0
    if actual < expected:
        print(
            f"FAIL: subtask {args.subtask}: test file has {actual} test cases "
            f"but plan declares {expected} scenarios",
            file=sys.stderr,
        )
        return 1
    print(
        f"OK: subtask {args.subtask} ({target['title']}) — {actual} test(s) "
        f">= {expected} scenario(s) in {target['test_file']}"
    )
    return 0


# ---------------------------------------------------------------------------
# Subcommand: review-save
# ---------------------------------------------------------------------------


IMAGE_EXTS = {".png", ".jpg", ".jpeg", ".gif", ".webp", ".svg", ".bmp"}


def cmd_review_save(args: argparse.Namespace) -> int:
    root = repo_root()
    reviews_dir = root / "docs" / "reviews"
    reviews_dir.mkdir(parents=True, exist_ok=True)
    date = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%d")
    safe_scope = re.sub(r"[^A-Za-z0-9._-]+", "-", args.scope).strip("-")
    base = f"{date}-{safe_scope}"

    attach_paths: list[pathlib.Path] = []
    if args.attach:
        for a in args.attach:
            p = pathlib.Path(a)
            if not p.exists():
                print(f"error: attachment not found: {p}", file=sys.stderr)
                return 2
            attach_paths.append(p.resolve())

    # Directory-mode when attachments are present; flat-file mode otherwise
    # (preserves backward compatibility with existing callers and tests).
    use_dir = bool(attach_paths)
    if use_dir:
        dir_target = reviews_dir / base
        i = 2
        while dir_target.exists():
            dir_target = reviews_dir / f"{base}-{i}"
            i += 1
        dir_target.mkdir(parents=True)
        target = dir_target / "index.md"
    else:
        target = reviews_dir / f"{base}.md"
        i = 2
        while target.exists():
            target = reviews_dir / f"{base}-{i}.md"
            i += 1

    if args.stdin:
        content = sys.stdin.read()
    elif args.content is not None:
        content = args.content
    else:
        print("error: provide --stdin or --content", file=sys.stderr)
        return 2

    header = (
        f"# Code Review — {args.scope}\n\n"
        f"**Date:** {dt.datetime.now(dt.timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')}\n"
        f"**Scope:** {args.scope}\n"
    )
    if args.plan:
        header += f"**Plan:** {args.plan}\n"
    if args.base_sha:
        header += f"**Base SHA:** {args.base_sha}\n"
    header += "\n---\n\n"

    # Copy attachments into the review directory and build an Evidence section.
    # Reserve the report filename so an attachment named 'index.md' (or whatever
    # the report file is called) is suffixed instead of silently overwritten by
    # the report write below.
    evidence_lines: list[str] = []
    if attach_paths:
        evidence_lines.append("## Evidence\n")
        import shutil
        reserved = {target.name}
        for src in attach_paths:
            candidate = src.name
            dst = target.parent / candidate
            j = 2
            while candidate in reserved or dst.exists():
                candidate = f"{src.stem}-{j}{src.suffix}"
                dst = target.parent / candidate
                j += 1
            shutil.copy2(src, dst)
            reserved.add(candidate)
            rel = dst.name  # same directory as the report
            if src.suffix.lower() in IMAGE_EXTS:
                evidence_lines.append(f"![{src.stem}]({rel})\n")
            else:
                evidence_lines.append(f"- [{src.name}]({rel})\n")
        evidence_lines.append("")

    body = content.rstrip() + "\n"
    if evidence_lines:
        body = body + "\n" + "\n".join(evidence_lines) + "\n"
    target.write_text(header + body)

    # Record in state
    data = _ensure_state_scaffold()
    entry: dict[str, Any] = {
        "scope": args.scope,
        "path": str(target.relative_to(root)),
        "recorded_at": dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "plan": args.plan or None,
        "base_sha": args.base_sha or None,
    }
    if attach_paths:
        entry["attachments"] = [p.name for p in attach_paths]
    data.setdefault("reviews", []).append(entry)
    write_state(data)

    # Link from plan if given and a "Reviews" section exists — append line, do not rewrite.
    if args.plan:
        plan_path = root / args.plan
        if plan_path.exists():
            plan_text = plan_path.read_text()
            rel = os.path.relpath(target, plan_path.parent)
            link_line = f"- [{args.scope}]({rel}) — {dt.datetime.now(dt.timezone.utc).strftime('%Y-%m-%d')}"
            if re.search(r"^##\s+Reviews\b", plan_text, re.M):
                # Append after the Reviews heading, preserving existing content.
                plan_text = re.sub(
                    r"(^##\s+Reviews\b.*?\n)",
                    r"\1" + link_line + "\n",
                    plan_text,
                    count=1,
                    flags=re.M,
                )
            else:
                sep = "" if plan_text.endswith("\n\n") else ("\n" if plan_text.endswith("\n") else "\n\n")
                plan_text += f"{sep}## Reviews\n\n{link_line}\n"
            plan_path.write_text(plan_text)

    print(str(target.relative_to(root)))
    return 0


